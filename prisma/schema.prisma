generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum ClassTimeOfDay {
  MORNING   @map("Sáng")
  AFTERNOON @map("Chiều")
  EVENING   @map("Tối")
}

enum ClassSectionType {
  LT_BT  @map("LT+BT")
  TN
  TH
  BT
  LT
  DA     @map("ĐA")
  TT
  DATN   @map("ĐATN")
  TTTN
  TTKT
  TTKS
  DATNKS @map("ĐATNKS")
}

enum SectionOpenGroup {
  A
  B
  AB
}

enum ClassSectionStatus {
  ADJUSTING_REGISTRATION @map("Điều chỉnh ĐK")
  REGISTRATION_CLOSED    @map("Kết thúc ĐK")
  CANCELLED              @map("Huỷ lớp")
  SCHEDULING             @map("Đang xếp TKB")
}

enum GradeLetter {
  A_PLUS @map("A+")
  A
  B_PLUS @map("B+")
  B
  C_PLUS @map("C+")
  C
  D_PLUS @map("D+")
  D
  F
}

enum OutboxEventType {
  REGISTRATION_SUCCESS
  REGISTRATION_FAILED
  REGISTRATION_CANCELLED
}

enum RegistrationBatchType {
  CREATE
  CANCEL
}

enum RegistrationBatchStatus {
  PENDING
  COMPLETED
}

enum RegistrationBatchItemStatus {
  PENDING
  SUCCESS
  CANCELLED
  FAILED
}

enum OutboxStatus {
  PENDING
  SENT
  FAILED
}

// ============================================================
// USERS
// ============================================================
model User {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentCode String   @unique @map("student_code") @db.VarChar(20)
  name        String   @db.VarChar(200)
  email       String   @unique @db.VarChar(200)
  password    String   @db.VarChar(255)
  role        UserRole @default(STUDENT)
  courseYear  Int?     @map("course_year")
  department  String?  @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  grades              StudentGrade[]
  registrationBatches RegistrationBatch[]

  @@map("users")
}

// ============================================================
// COURSES
// ============================================================
model Course {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique @db.VarChar(20)
  name           String   @db.VarChar(300)
  englishName    String?  @map("english_name") @db.VarChar(300)
  credits        Int
  tuitionCredits Decimal? @map("tuition_credits") @db.Decimal(5, 1)
  courseLoad     String?  @map("khoi_luong") @db.VarChar(20)
  department     String?  @db.VarChar(100)
  prerequisite   String?  @db.Text // prerequisite course code or expression from CSV
  weight         Decimal  @default(1) @db.Decimal(3, 1)

  classSections ClassSection[]
  grades        StudentGrade[]

  @@map("courses")
}

// ============================================================
// CLASS SECTIONS
// ============================================================
model ClassSection {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionCode       String  @map("ma_lop") @db.VarChar(20)
  linkedSectionCode String? @map("ma_lop_kem") @db.VarChar(20) // linked lecture/lab section
  courseId          String  @map("course_id") @db.Uuid
  semester          String  @db.VarChar(10)

  // Schedule
  dayOfWeek   Int?            @map("thu") @db.Integer // 2-7
  timeOfDay   ClassTimeOfDay? @map("kip")
  startPeriod Int?            @map("tiet_bd") // start period
  endPeriod   Int?            @map("tiet_kt") // end period
  timeRange   String?         @map("thoi_gian") @db.VarChar(20) // 0645-0910
  weekRange   String?         @map("tuan") @db.VarChar(50) // 25-32,34-42
  room        String?         @map("phong") @db.VarChar(50)

  // Classification
  sectionType   ClassSectionType?   @map("loai_lop")
  // LT+BT | TN | DA | TT | DATN | TTTN | BT | LT | TH
  openingGroup  SectionOpenGroup?   @map("dat_mo")
  sectionStatus ClassSectionStatus? @map("trang_thai")
  requiresLab   Boolean             @default(false) @map("can_tn")
  note          String?             @map("ghi_chu")

  // Capacity
  maxCapacity     Int @default(0) @map("sl_max")
  registeredCount Int @default(0) @map("sl_dk")

  createdAt DateTime @default(now()) @map("created_at")

  course     Course                  @relation(fields: [courseId], references: [id])
  batchItems RegistrationBatchItem[]

  @@unique([sectionCode, timeRange, dayOfWeek], name: "class_sections_ma_lop_thoi_gian_thu_key")
  @@index([courseId], name: "idx_class_sections_course")
  @@index([semester], name: "idx_class_sections_semester")
  @@index([sectionCode], name: "idx_class_sections_ma_lop")
  @@map("class_sections")
}

// ============================================================
// REGISTRATION BATCHES
// ============================================================
model RegistrationBatch {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String                  @map("user_id") @db.Uuid
  semester    String                  @db.VarChar(10)
  type        RegistrationBatchType
  // CREATE | CANCEL
  status      RegistrationBatchStatus
  // PENDING | COMPLETED
  totalItems  Int                     @map("total_items")
  createdAt   DateTime                @default(now()) @map("created_at")
  processedAt DateTime?               @map("processed_at")

  user  User                    @relation(fields: [userId], references: [id])
  items RegistrationBatchItem[]

  @@index([userId, createdAt(sort: Desc)], name: "idx_reg_batches_user_created")
  @@index([semester], name: "idx_reg_batches_semester")
  @@map("registration_batches")
}

model RegistrationBatchItem {
  id             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId        String                      @map("batch_id") @db.Uuid
  classSectionId String?                     @map("class_section_id") @db.Uuid
  status         RegistrationBatchItemStatus
  // PENDING | SUCCESS | CANCELLED | FAILED
  failureReason  String?                     @map("failure_reason") @db.Text
  remainingSlots Int?                        @map("remaining_slots")
  createdAt      DateTime                    @default(now()) @map("created_at")
  processedAt    DateTime?                   @map("processed_at")

  batch        RegistrationBatch @relation(fields: [batchId], references: [id])
  classSection ClassSection?     @relation(fields: [classSectionId], references: [id])

  @@index([batchId], name: "idx_reg_batch_items_batch")
  @@index([classSectionId], name: "idx_reg_batch_items_class_section")
  @@map("registration_batch_items")
}

// ============================================================
// STUDENT GRADES
// ============================================================
model StudentGrade {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  courseId    String      @map("course_id") @db.Uuid
  semester    String      @db.VarChar(10)
  gradeLetter GradeLetter @map("grade_letter")
  // A | B+ | B | C+ | C | D+ | D | F
  gradePoint  Decimal?    @map("grade_point") @db.Decimal(3, 1) // 4.0 scale
  gradeNumber Decimal?    @map("grade_number") @db.Decimal(4, 1) // 0-10 scale
  createdAt   DateTime    @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId, semester])
  @@index([userId, courseId], name: "idx_grades_user_course")
  @@map("student_grades")
}

// ============================================================
// REGISTRATION SLOTS
// ============================================================
model RegistrationSlot {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  semester      String    @db.VarChar(10)
  name          String?   @db.VarChar(100)
  studentFilter Json      @map("student_filter") @db.JsonB
  // { course_year: 2021 } or { department: "CNTT" }
  openAt        DateTime  @map("open_at")
  closeAt       DateTime  @map("close_at")
  prewarmAt     DateTime  @map("prewarm_at") // usually = open_at - 15 minutes
  isPrewarmed   Boolean   @default(false) @map("is_prewarmed")
  prewarmedAt   DateTime? @map("prewarmed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([semester], name: "idx_registration_slots_semester")
  @@map("registration_slots")
}

// ============================================================
// SYSTEM SETTINGS (singleton row, id = 1)
// ============================================================
model SystemSetting {
  id                    Int      @id @default(1)
  currentSemester       String   @map("current_semester") @db.VarChar(10)
  semesterStartDate     String   @map("semester_start_date") @db.VarChar(20)
  semesterEndDate       String   @map("semester_end_date") @db.VarChar(20)
  registrationOpenAt    DateTime @default(now()) @map("registration_open_at")
  registrationCloseAt   DateTime @default(dbgenerated("'2099-12-31 23:59:59'::timestamp without time zone")) @map("registration_close_at")
  maxCreditsPerSemester Int      @map("max_credits_per_semester")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ============================================================
// OUTBOX - ASYNC EMAIL DELIVERY
// ============================================================
model Outbox {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType  OutboxEventType @map("event_type")
  // REGISTRATION_SUCCESS | REGISTRATION_FAILED | REGISTRATION_CANCELLED
  payload    Json            @db.JsonB
  // { studentId, studentEmail, studentName, courseName, sectionCode, semester }
  status     OutboxStatus    @default(PENDING)
  // PENDING | SENT | FAILED
  retryCount Int             @default(0) @map("retry_count")
  createdAt  DateTime        @default(now()) @map("created_at")
  sentAt     DateTime?       @map("sent_at")
  error      String?

  @@index([status], name: "idx_outbox_status")
  @@index([createdAt], name: "idx_outbox_created")
  @@map("outbox")
}

// ============================================================
// BATCH PROCESSING LOGS — Worker metrics cho Admin Dashboard
// ============================================================
model BatchProcessingLog {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId              String                @map("batch_id") @db.Uuid
  semester             String                @db.VarChar(10)
  batchType            RegistrationBatchType @map("batch_type")

  // Timing
  queuedAt             DateTime              @map("queued_at")
  processingStartedAt  DateTime              @map("processing_started_at")
  processingEndedAt    DateTime              @map("processing_ended_at")
  queueWaitMs          Int                   @map("queue_wait_ms")
  processingDurationMs Int                   @map("processing_duration_ms")

  // Results
  totalItems           Int                   @map("total_items")
  successItems         Int                   @map("success_items")
  failedItems          Int                   @map("failed_items")

  createdAt            DateTime              @default(now()) @map("created_at")

  @@index([semester], name: "idx_batch_log_semester")
  @@index([createdAt], name: "idx_batch_log_created")
  @@index([batchType], name: "idx_batch_log_type")
  @@map("batch_processing_logs")
}
