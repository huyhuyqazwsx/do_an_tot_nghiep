# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=do_an
POSTGRES_PORT=5432
# Chuỗi kết nối Prisma sử dụng (bắt buộc)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/do_an?schema=public

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=            # bỏ trống nếu Redis không đặt mật khẩu

# ==========================================
# RabbitMQ
# ==========================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# URL kết nối mà ứng dụng sử dụng (mặc định: amqp://guest:guest@localhost:5672)
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
# RABBITMQ_QUEUE=do_an_queue
# RABBITMQ_DEAD_LETTER_QUEUE=do_an_queue.dead
# RABBITMQ_REGISTRATION_MAX_RETRIES=6

# ==========================================
# Mail (Gmail SMTP) — dùng cho OTP quên mật khẩu & email thông báo kết quả ĐK
# Tạo App Password tại: https://myaccount.google.com/apppasswords
# ==========================================
MAIL_USER=your-email@gmail.com
MAIL_APP_PASSWORD=your-gmail-app-password

# ==========================================
# JWT
# ==========================================
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# ==========================================
# Khác (tùy chọn)
# ==========================================
# PORT=3000                  # cổng HTTP của API
# ENABLE_DLQ_CONSUMER=false  # bật consumer xử lý Dead-Letter Queue (worker riêng)
# DEFAULT_ADMIN_EMAIL=       # email gán cho tài khoản admin mặc định khi tự khởi tạo
